    }

    if(tester.test_map_get() == 77) {
        console.println("PASS map_get")
    } else {
        console.println("FAIL map_get")
    }

    // Test: const auto-borrow (CBOR-01) — const struct auto-borrows as *const T
    if(tester.test_const_auto_borrow() == 7.0) {
        console.println("PASS const_auto_borrow")
    } else {
        console.println("FAIL const_auto_borrow")
    }

    // Test: var caller of promoted function — also emits mut& arg at call site
    if(tester.test_var_caller_promoted() == 30.0) {
        console.println("PASS var_caller_promoted")
    } else {
        console.println("FAIL var_caller_promoted")
    }

    // Test: @copy() on const value bypasses auto-borrow (CBOR-02)
    if(tester.test_const_copy() == 11.0) {
        console.println("PASS const_copy")
    } else {
        console.println("FAIL const_copy")
    }

    // Cross-module qualified is check — tests grammar/builder/codegen for is module.Type
    const iso = tester.IsTestType(val: 42)
    if(iso is tester.IsTestType) {
        console.println("PASS is_qualified")
    } else {
        console.println("FAIL is_qualified")
    }

    // is not with a type that differs — i32 literal is not tester.IsTestType
    const iso_n: i32 = 99
    if(iso_n is not tester.IsTestType) {
        console.println("PASS is_not_qualified")
    } else {
        console.println("FAIL is_not_qualified")
    }

    // Test: (Error | void) — success path returns void, no error
    if(tester.test_error_void_ok() == 1) {
        console.println("PASS error_void_ok")
    } else {
        console.println("FAIL error_void_ok")
    }

    // Test: (Error | void) — error path returns error
    if(tester.test_error_void_fail() == 1) {
        console.println("PASS error_void_fail")
    } else {
        console.println("FAIL error_void_fail")
    }

    // Test: @cast(EnumType, int) → @enumFromInt
    if(tester.test_cast_to_enum() == 1) {
        console.println("PASS cast_to_enum")
    } else {
        console.println("FAIL cast_to_enum")
    }

    // Test: (null | (A | B | C)) → ?(union(enum){...})
    if(tester.test_null_multi_union() == 1) {
        console.println("PASS null_multi_union")
    } else {
        console.println("FAIL null_multi_union")
    }

    // Test: ZeroField() → ZeroField{} (empty struct construction)
    if(tester.test_empty_struct_construct() == 1) {
        console.println("PASS empty_struct_construct")
    } else {
        console.println("FAIL empty_struct_construct")
    }

    // Test: match guards — (x if cond) arms
    if(tester.match_guard(5) == 1 and tester.match_guard(0 - 3) == 0 - 1 and tester.match_guard(0) == 0) {
        console.println("PASS match_guard")
    } else {
        console.println("FAIL match_guard")
    }

    // Test: match guard with enclosing scope variable
    if(tester.match_guard_scope(10, 5) == 1 and tester.match_guard_scope(3, 5) == 0 and tester.match_guard_scope(5, 5) == 0) {
        console.println("PASS match_guard_scope")
    } else {
        console.println("FAIL match_guard_scope")
    }

    // Test: negative literal arguments
    if(tester.test_negative_args() == 1) {
        console.println("PASS negative_literal_args")
    } else {
        console.println("FAIL negative_literal_args")
    }

    // Test: const& expr as call argument (explicit const borrow passing)
    if(tester.test_const_borrow_arg() == 42) {
        console.println("PASS const_borrow_arg")
    } else {
        console.println("FAIL const_borrow_arg")
    }

    // Struct introspection
    if(tester.test_has_field() == 1) {
        console.println("PASS has_field")
    } else {
        console.println("FAIL has_field")
    }

