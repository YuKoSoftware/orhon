    if(tester.sum_range(5) == 10) {
        console.println("PASS for_range")
    } else {
        console.println("FAIL for_range")
    }

    if(tester.sum_while_continue(5) == 10) {
        console.println("PASS while_continue")
    } else {
        console.println("FAIL while_continue")
