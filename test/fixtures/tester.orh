pub func test_null_multi_union() i32 {
    const val: NullUnion(i32) = 42
    if(val is null) {
        return 0
    }
    return 1
}

// ─── Bug fix: ZeroField() → ZeroField{} ──────────────────────

pub struct ZeroField {}

pub func test_empty_struct_construct() i32 {
    const z: ZeroField = ZeroField()
    return 1
}

// ─── Match — guards ──────────────────────────────────────────

pub func match_guard(n: i32) i32 {
    match(n) {
        (x if x > 0)  => { return 1 }
        (x if x < 0)  => { return 0 - 1 }
        else           => { return 0 }
    }
}

test "match_guard" {
    @assert(match_guard(5) == 1)
    @assert(match_guard(0 - 3) == 0 - 1)
    @assert(match_guard(0) == 0)
}

pub func match_guard_scope(n: i32, threshold: i32) i32 {
    match(n) {
        (x if x > threshold)  => { return 1 }
        else                  => { return 0 }
    }
}

test "match_guard_scope" {
    @assert(match_guard_scope(10, 5) == 1)
    @assert(match_guard_scope(3, 5) == 0)
    @assert(match_guard_scope(5, 5) == 0)
}

// ─── Negative literal arguments ──────────────────────────────

pub func negate_helper(a: f32, b: f32) f32 {
    return a + b
}

pub func test_negative_args() i32 {
    const result: f32 = negate_helper(-0.5, -1.0)
    if(result == -1.5) {
        return 1
    }
    return 0
}

test "negative literal args" {
    @assert(test_negative_args() == 1)
}

// ─── Const Borrow Expr ───────────────────────────────────────

// const& expr in call argument position — explicit const borrow passing.
// Uses a struct parameter to verify the const& syntax parses and compiles.

pub struct BorrowTarget {
    pub value: i32
}

func read_borrow_target(t: const& BorrowTarget) i32 {
    return t.value
}

pub func test_const_borrow_arg() i32 {
    const target: BorrowTarget = BorrowTarget(value: 42)
    return read_borrow_target(const& target)
}

test "const borrow expr as call argument" {
    @assert(test_const_borrow_arg() == 42)
}

// ─── Struct Introspection ────────────────────────────────────

pub func test_has_field() i32 {
    if(@hasField(Vec2, "x")) {
        return 1
    }
    return 0
}

pub func test_has_field_missing() i32 {
    if(@hasField(Vec2, "z")) {
        return 0
    }
    return 1
}

pub func test_has_field_value() i32 {
    var v: Vec2 = Vec2(x: 1.0, y: 2.0)
    if(@hasField(v, "x")) {
        return 1
    }
    return 0
}

pub func test_has_decl() i32 {
    if(@hasDecl(Counter, "create")) {
        return 1
    }
    return 0
}

pub func test_has_decl_missing() i32 {
    if(@hasDecl(Vec2, "nonexistent")) {
        return 0
    }
    return 1
}

pub func test_field_type() i32 {
    // @fieldType(Vec2, "x") is f32, @size(f32) == 4
    if(@size(@fieldType(Vec2, "x")) == 4) {
        return 1
    }
    return 0
}

pub func test_field_names() i32 {
    // @fieldNames(Vec2) returns a comptime slice — .len == 2 (x, y)
    if(@fieldNames(Vec2).len == 2) {
        return 1
    }
    return 0
}
