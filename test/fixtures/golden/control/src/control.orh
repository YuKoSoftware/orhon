module control

pub func classify(n: i32) str {
    if (n > 0) {
        return "positive"
    } elif (n < 0) {
        return "negative"
    } else {
        return "zero"
    }
}

pub func sum_to(n: i32) i32 {
    var total: i32 = 0
    var i: i32 = 1
    while (i <= n) {
        total = total + i
        i = i + 1
    }
    return total
}
