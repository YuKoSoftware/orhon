module fixture

#version = (1, 0, 0)
#build   = exe

// negation on unsigned types — should error

func neg_u8() u8 {
    const x: u8 = 5
    return -x
}

func neg_u32() u32 {
    const x: u32 = 5
    return -x
}

func neg_usize() usize {
    const x: usize = 5
    return -x
}

// negation on signed/float — should be fine

func neg_i32() i32 {
    const x: i32 = 5
    return -x
}

func neg_f64() f64 {
    const x: f64 = 5.0
    return -x
}

func main() void { }
