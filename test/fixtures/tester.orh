// Exported struct for cross-module is test (used in tester_main.orh)

pub struct IsTestType {
    val: i32
}

// ─── ErrorUnion(void) ───────────────────────────────────────

pub func do_side_effect(flag: bool) ErrorUnion(void) {
    if(flag) {
        return Error("side effect failed")
    }
    return
}

pub func test_error_void_ok() i32 {
    const result = do_side_effect(false)
    if(result is Error) {
        return 0
    }
    return 1
}

pub func test_error_void_fail() i32 {
    const result = do_side_effect(true)
    if(result is Error) {
        return 1
    }
    return 0
}

