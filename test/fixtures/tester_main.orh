    // Test: compt func returning anonymous struct with method
    if(tester.test_compt_struct() == 42) {
        console.println("PASS compt_struct")
    } else {
        console.println("FAIL compt_struct")
    }

    // Test: compt struct default field values
    if(tester.test_compt_struct_defaults() == 0) {
        console.println("PASS compt_struct_defaults")
    } else {
        console.println("FAIL compt_struct_defaults")
