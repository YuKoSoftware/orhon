        console.println("FAIL enum_usage")
    }

    if(tester.test_enum_method() == 1) {
        console.println("PASS enum_method")
    } else {
        console.println("FAIL enum_method")
    }

    if(tester.nested_scope() == 6) {
        console.println("PASS nested_scopes")
    } else {
        console.println("FAIL nested_scopes")
    }

    if(tester.test_tuple() == 10) {
        console.println("PASS tuple")
    } else {
        console.println("FAIL tuple")
    }

    if(tester.test_tuple_destruct() == 10) {
        console.println("PASS tuple_destruct")
    } else {
        console.println("FAIL tuple_destruct")
    }

    if(tester.sum_slice_test() == 6) {
        console.println("PASS slice_for")
    } else {
        console.println("FAIL slice_for")
    }

    if(tester.indexed_sum() == 63) {
        console.println("PASS for_index")
    } else {
        console.println("FAIL for_index")
