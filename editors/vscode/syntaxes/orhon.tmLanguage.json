{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Orhon",
  "scopeName": "source.orhon",
  "patterns": [
    { "include": "#comments" },
    { "include": "#metadata" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.orhon",
          "match": "//.*$"
        },
        {
          "name": "comment.block.orhon",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "meta.preprocessor.orhon",
          "match": "^\\s*(#\\w+)\\b",
          "captures": {
            "1": { "name": "keyword.other.metadata.orhon" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orhon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orhon",
              "match": "\\\\[nrt\\\\\"0]"
            },
            {
              "name": "meta.interpolation.orhon",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.orhon" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.orhon" }
              },
              "patterns": [
                { "include": "source.orhon" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.orhon",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.orhon",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.orhon",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.float.orhon",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.orhon",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.orhon",
          "match": "\\b(if|elif|else|for|while|match|return|break|continue|defer)\\b"
        },
        {
          "name": "keyword.declaration.orhon",
          "match": "\\b(func|var|const|struct|enum|bitfield|module|import|pub|extern|compt|test)\\b"
        },
        {
          "name": "keyword.operator.orhon",
          "match": "\\b(and|or|not|as|is|cast|copy|move|swap)\\b"
        },
        {
          "name": "keyword.other.orhon",
          "match": "\\b(thread|any|self|main)\\b"
        },
        {
          "name": "constant.language.orhon",
          "match": "\\b(true|false|null|void|Error)\\b"
        },
        {
          "name": "support.function.builtin.orhon",
          "match": "\\b(assert|size|align|typename|typeid|wrap|sat|overflow)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.orhon",
          "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|isize|usize|f16|bf16|f32|f64|f128|bool|String|type)\\b"
        },
        {
          "name": "storage.type.builtin.orhon",
          "match": "\\b(List|Map|Set|Ring|ORing|Ptr|RawPtr|VolatilePtr|Thread|Async|File|Dir|Format|Version)\\b"
        },
        {
          "comment": "User-defined type names (PascalCase)",
          "name": "entity.name.type.orhon",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function declaration name",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.orhon" },
            "2": { "name": "entity.name.function.orhon" }
          }
        },
        {
          "comment": "Function call",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.orhon" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.orhon",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.orhon",
          "match": "\\+=|-=|\\*=|/=|="
        },
        {
          "name": "keyword.operator.arithmetic.orhon",
          "match": "\\+\\+|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.orhon",
          "match": "<<|>>|\\^|&|\\|"
        },
        {
          "name": "keyword.operator.range.orhon",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arrow.orhon",
          "match": "=>"
        },
        {
          "name": "keyword.operator.scope.orhon",
          "match": "::"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.orhon",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.orhon",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.orhon",
          "match": ";"
        }
      ]
    }
  }
}
