module testing

// testing — test assertion helpers for Orhon programs
// Import with: import std::testing
// All assertions panic on failure with a descriptive message.

// Assert a condition is true

pub bridge func assertTrue(value: bool) void

// Assert a condition is false

pub bridge func assertFalse(value: bool) void

// Assert two strings are equal

pub bridge func assertEq(a: String, b: String) void

// Assert two strings are not equal

pub bridge func assertNe(a: String, b: String) void

// Assert a string contains a substring

pub bridge func assertContains(text: String, sub: String) void

// Unconditional test failure with a message

pub bridge func fail(msg: String) void
