module encoding

// encoding — base64 and hex encoding/decoding for Orhon programs
// Import with: import std::encoding

// Encode bytes to base64 string

pub bridge func base64Encode(data: String) String

// Decode base64 string to bytes

pub bridge func base64Decode(data: String) (Error | String)

// Encode bytes to lowercase hex string

pub bridge func hexEncode(data: String) String

// Decode hex string to bytes

pub bridge func hexDecode(data: String) (Error | String)
