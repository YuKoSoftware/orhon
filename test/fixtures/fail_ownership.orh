module fixture

#name    = "fail_ownership"
#version = (1, 0, 0)
#build   = exe

import std::console

struct Data {
    pub name: str
}

// use after move

func use_after_move() void {
    var a: Data = Data(name: "hello")
    var b: Data = a
    console.println(a.name)
}

// use after @splitAt

func use_after_split() void {
    const arr: [4]i32 = [1, 2, 3, 4]
    const left, right = @splitAt(arr, 2)
    const x: i32 = arr[0]
}

func main() void { }
