module main

#name    = "comptest"
#version = Version(1, 0, 0)
#build   = exe
#bitsize = 32

import std::console
import tester

func main() void {
    // Runtime correctness — each check calls a tester function
    // and prints PASS or FAIL. test.sh verifies no FAIL lines.

    if(tester.add(2, 3) == 5) {
        console.print("PASS add\n")
    } else {
        console.print("FAIL add\n")
    }

    if(tester.sub(10, 3) == 7) {
        console.print("PASS sub\n")
    } else {
        console.print("FAIL sub\n")
    }

    if(tester.factorial(5) == 120) {
        console.print("PASS factorial\n")
    } else {
        console.print("FAIL factorial\n")
    }

    if(tester.is_positive(1)) {
        console.print("PASS is_positive\n")
    } else {
        console.print("FAIL is_positive\n")
    }

    if(tester.test_compound() == 70) {
        console.print("PASS compound\n")
    } else {
        console.print("FAIL compound\n")
    }

    if(tester.sum_to(10) == 55) {
        console.print("PASS sum_to\n")
    } else {
        console.print("FAIL sum_to\n")
    }

    if(tester.match_test(1) == 10) {
        console.print("PASS match\n")
    } else {
        console.print("FAIL match\n")
    }

    if(tester.match_test(99) == 0) {
        console.print("PASS match_default\n")
    } else {
        console.print("FAIL match_default\n")
    }

    if(tester.first_over(5) == 6) {
        console.print("PASS break_continue\n")
    } else {
        console.print("FAIL break_continue\n")
    }

    if(tester.abs(0 - 7) == 7) {
        console.print("PASS abs\n")
    } else {
        console.print("FAIL abs\n")
    }

    if(tester.doubled(21) == 42) {
        console.print("PASS compt_func\n")
    } else {
        console.print("FAIL compt_func\n")
    }

    if(tester.make_internal() == 42) {
        console.print("PASS struct_instantiation\n")
    } else {
        console.print("FAIL struct_instantiation\n")
    }

    if(tester.test_defaults() == 42) {
        console.print("PASS default_fields\n")
    } else {
        console.print("FAIL default_fields\n")
    }

    if(tester.test_defaults_override() == 99) {
        console.print("PASS default_override\n")
    } else {
        console.print("FAIL default_override\n")
    }

    if(tester.test_static_method() == 10) {
        console.print("PASS static_method\n")
    } else {
        console.print("FAIL static_method\n")
    }

    if(tester.test_mutable_method() == 3) {
        console.print("PASS mutable_method\n")
    } else {
        console.print("FAIL mutable_method\n")
    }

    if(tester.test_error_ok() == 5) {
        console.print("PASS error_ok\n")
    } else {
        console.print("FAIL error_ok\n")
    }

    if(tester.test_error_fail() == 0 - 1) {
        console.print("PASS error_fail\n")
    } else {
        console.print("FAIL error_fail\n")
    }

    if(tester.test_null_some() == 50) {
        console.print("PASS null_some\n")
    } else {
        console.print("FAIL null_some\n")
    }

    if(tester.test_null_none() == 0 - 1) {
        console.print("PASS null_none\n")
    } else {
        console.print("FAIL null_none\n")
    }

    if(tester.test_null_reassign() == 42) {
        console.print("PASS null_reassign\n")
    } else {
        console.print("FAIL null_reassign\n")
    }

    if(tester.test_enum() == 1) {
        console.print("PASS enum_usage\n")
    } else {
        console.print("FAIL enum_usage\n")
    }

    if(tester.test_enum_method() == 1) {
        console.print("PASS enum_method\n")
    } else {
        console.print("FAIL enum_method\n")
    }

    if(tester.nested_scope() == 6) {
        console.print("PASS nested_scopes\n")
    } else {
        console.print("FAIL nested_scopes\n")
    }

    if(tester.test_tuple() == 10) {
        console.print("PASS tuple\n")
    } else {
        console.print("FAIL tuple\n")
    }

    if(tester.test_tuple_destruct() == 10) {
        console.print("PASS tuple_destruct\n")
    } else {
        console.print("FAIL tuple_destruct\n")
    }

    if(tester.sum_slice_test() == 6) {
        console.print("PASS slice_for\n")
    } else {
        console.print("FAIL slice_for\n")
    }

    if(tester.indexed_sum() == 63) {
        console.print("PASS for_index\n")
    } else {
        console.print("FAIL for_index\n")
    }

    if(tester.sum_range(5) == 10) {
        console.print("PASS for_range\n")
    } else {
        console.print("FAIL for_range\n")
    }

    if(tester.sum_while_continue(5) == 10) {
        console.print("PASS while_continue\n")
    } else {
        console.print("FAIL while_continue\n")
    }

    const arr: [3]i32 = [10, 20, 30]
    if(tester.sum_fixed_array(arr) == 60) {
        console.print("PASS fixed_array\n")
    } else {
        console.print("FAIL fixed_array\n")
    }

    if(tester.array_index_test() == 20) {
        console.print("PASS array_index\n")
    } else {
        console.print("FAIL array_index\n")
    }

    if(tester.slice_expr_test() == 9) {
        console.print("PASS slice_expr\n")
    } else {
        console.print("FAIL slice_expr\n")
    }

    if(tester.apply_fn(tester.triple, 5) == 15) {
        console.print("PASS func_ptr\n")
    } else {
        console.print("FAIL func_ptr\n")
    }

    if(tester.call_via_ptr() == 12) {
        console.print("PASS func_ptr_var\n")
    } else {
        console.print("FAIL func_ptr_var\n")
    }

    if(tester.cast_to_i64(42) == 42) {
        console.print("PASS cast_int\n")
    } else {
        console.print("FAIL cast_int\n")
    }

    if(tester.cast_to_f32(7) == 7.0) {
        console.print("PASS cast_float\n")
    } else {
        console.print("FAIL cast_float\n")
    }

    if(tester.cast_float_to_int() == 3) {
        console.print("PASS cast_float_to_int\n")
    } else {
        console.print("FAIL cast_float_to_int\n")
    }

    if(tester.raw_ptr_read() == 99) {
        console.print("PASS raw_ptr\n")
    } else {
        console.print("FAIL raw_ptr\n")
    }

    if(tester.safe_ptr_read() == 77) {
        console.print("PASS safe_ptr\n")
    } else {
        console.print("FAIL safe_ptr\n")
    }

    if(tester.typeid_same() == 1) {
        console.print("PASS typeid_same\n")
    } else {
        console.print("FAIL typeid_same\n")
    }

    if(tester.typeid_diff() == 1) {
        console.print("PASS typeid_diff\n")
    } else {
        console.print("FAIL typeid_diff\n")
    }

    if(tester.match_range(3) == 1 and tester.match_range(5) == 2 and tester.match_range(7) == 0) {
        console.print("PASS match_range\n")
    } else {
        console.print("FAIL match_range\n")
    }

    if(tester.match_string("hello") == 1 and tester.match_string("world") == 2 and tester.match_string("x") == 0) {
        console.print("PASS match_string\n")
    } else {
        console.print("FAIL match_string\n")
    }

    if(tester.test_list() == 20) {
        console.print("PASS list\n")
    } else {
        console.print("FAIL list\n")
    }

    if(tester.test_list_len() == 40) {
        console.print("PASS list_len\n")
    } else {
        console.print("FAIL list_len\n")
    }

    if(tester.test_map() == 42) {
        console.print("PASS map\n")
    } else {
        console.print("FAIL map\n")
    }

    if(tester.test_set() == 1) {
        console.print("PASS set\n")
    } else {
        console.print("FAIL set\n")
    }

    if(tester.test_bitfield() == 1) {
        console.print("PASS bitfield\n")
    } else {
        console.print("FAIL bitfield\n")
    }

    if(tester.test_wrap() == 5) {
        console.print("PASS wrap\n")
    } else {
        console.print("FAIL wrap\n")
    }

    if(tester.test_sat() == 15) {
        console.print("PASS sat\n")
    } else {
        console.print("FAIL sat\n")
    }

    if(tester.test_overflow_ok() == 8) {
        console.print("PASS overflow\n")
    } else {
        console.print("FAIL overflow\n")
    }

    console.print("TESTER:DONE\n")
}
