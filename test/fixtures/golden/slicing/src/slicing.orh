module slicing

pub func fixed_sum() i32 {
    const arr: [4]i32 = [1, 2, 3, 4]
    var total: i32 = 0
    var i: i32 = 0
    while(i < 4) : (i += 1) {
        total += arr[i]
    }
    return total
}

pub func slice_expr() i32 {
    var arr: [5]i32 = [1, 2, 3, 4, 5]
    const part: []i32 = arr[1..4]
    var total: i32 = 0
    for(part) |val| {
        total += val
    }
    return total
}

pub func sum_slice(s: []i32) i32 {
    var total: i32 = 0
    for(s) |val| {
        total += val
    }
    return total
}

pub func range_sum(n: i32) i32 {
    var total: i32 = 0
    for(0..n) |i| {
        total += @cast(i32, i)
    }
    return total
}
