module tester

// ═══════════════════════════════════════════════════════════════
// Orhon compiler test module — exercises all implemented features.
// If this compiles, the pipeline works. Tests verify correctness.
// Runtime output is checked by test.sh for known values.
// ═══════════════════════════════════════════════════════════════

import std::console

// ─── Variables ───────────────────────────────────────────────

const immutable_const: i32 = 20
const COMPT_VALUE: i32 = 1024

// ─── Structs ─────────────────────────────────────────────────

pub struct Vec2 {
    pub x: f32
    pub y: f32
}

struct Internal {
    value: i32
    name: String
}

pub struct WithDefaults {
    pub name: String
    pub value: i32 = 42
    pub flag: bool = true
}

pub struct Counter {
    pub count: i32

    pub func create(start: i32) Counter {
        return Counter(count: start)
    }

    pub func get(self: const &Counter) i32 {
        return self.count
    }

    pub func increment(self: &Counter) void {
        self.count = self.count + 1
    }
}

// ─── Enums ───────────────────────────────────────────────────

pub enum(u8) Color {
    Red
    Green
    Blue
}

pub enum(u8) Direction {
    North
    South
    East
    West

    pub func opposite(self: const &Direction) Direction {
        match(self) {
            North => { return South }
            South => { return North }
            East  => { return West }
            West  => { return East }
        }
        return North
    }
}

// ─── Functions ───────────────────────────────────────────────

// basic function

pub func add(a: i32, b: i32) i32 {
    return a + b
}

// pub function

pub func sub(a: i32, b: i32) i32 {
    return a - b
}

// recursive function

pub func factorial(n: i32) i32 {
    if(n <= 1) {
        return 1
    }
    return n * factorial(n - 1)
}

// compt function

pub compt func doubled(n: i32) i32 {
    return n * 2
}

// function returning bool

pub func is_positive(n: i32) bool {
    return n > 0
}

// function with default parameter

pub func add_default(a: i32, b: i32 = 10) i32 {
    return a + b
}

// function with String

pub func greeting() String {
    return "hello" ++ " " ++ "world"
}

// ─── Arithmetic operators ────────────────────────────────────

pub func test_arithmetic(a: i32, b: i32) i32 {
    var result: i32 = a + b
    result = result - 1
    result = result * 2
    result = result / 2
    result = result % 7
    return result
}

// ─── Comparison operators ────────────────────────────────────

pub func test_comparisons(a: i32, b: i32) bool {
    if(a == b) { return true }
    if(a != b) { return true }
    if(a < b) { return true }
    if(a > b) { return true }
    if(a <= b) { return true }
    if(a >= b) { return true }
    return false
}

// ─── Logical operators ───────────────────────────────────────

pub func test_logical(a: bool, b: bool) bool {
    if(a and b) { return true }
    if(a or b) { return true }
    if(not a) { return true }
    return false
}

// ─── Bitwise operators ───────────────────────────────────────

pub func test_bitwise(a: i32, b: i32) i32 {
    var r: i32 = a & b
    r = r | a
    r = r ^ b
    r = a << 1
    r = a >> 1
    return r
}

// ─── Compound assignment ─────────────────────────────────────

pub func test_compound() i32 {
    var x: i32 = 100
    x += 10
    x -= 5
    x *= 2
    x /= 3
    return x
}

// ─── If / Else ───────────────────────────────────────────────

pub func abs(n: i32) i32 {
    if(n < 0) {
        return 0 - n
    } else {
        return n
    }
}

// ─── While loop ──────────────────────────────────────────────

pub func sum_to(n: i32) i32 {
    var total: i32 = 0
    var i: i32 = 1
    while(i <= n) {
        total += i
        i += 1
    }
    return total
}

// ─── Fixed-size arrays ───────────────────────────────────────

pub func sum_fixed_array(arr: [3]i32) i32 {
    var total: i32 = 0
    var i: i32 = 0
    while(i < 3) : (i += 1) {
        total += arr[i]
    }
    return total
}

pub func array_index_test() i32 {
    const arr: [3]i32 = [10, 20, 30]
    return arr[1]
}

// slice expression — arr[a..b] returns a sub-slice

pub func slice_expr_test() i32 {
    var arr: [5]i32 = [1, 2, 3, 4, 5]
    const part: []i32 = arr[1..4]
    var total: i32 = 0
    for(part) |val| {
        total += val
    }
    return total
}

// ─── Function pointers ───────────────────────────────────────

pub func triple(x: i32) i32 {
    return x * 3
}

pub func apply_fn(f: func(i32) i32, x: i32) i32 {
    return f(x)
}

pub func call_via_ptr() i32 {
    const f: func(i32) i32 = triple
    return f(4)
}

// ─── Cast ────────────────────────────────────────────────────

pub func cast_to_i64(x: i32) i64 {
    return cast(i64, x)
}

pub func cast_to_f32(x: i32) f32 {
    return cast(f32, x)
}

pub func cast_float_to_int() i32 {
    return cast(i32, 3.7)
}

// ─── While with continue expression ─────────────────────────

pub func sum_while_continue(n: i32) i32 {
    var total: i32 = 0
    var i: i32 = 0
    while(i < n) : (i += 1) {
        total += i
    }
    return total
}

// ─── For loop ────────────────────────────────────────────────

pub func sum_slice(arr: []i32) i32 {
    var total: i32 = 0
    for(arr) |val| {
        total += val
    }
    return total
}

// for loop over slice — tests iteration over array elements

pub func sum_slice_test() i32 {
    const arr: [3]i32 = [1, 2, 3]
    var total: i32 = 0
    for(arr) |val| {
        total += val
    }
    return total
}

// for loop with index — iterates array and index simultaneously

pub func indexed_sum() i32 {
    const arr: [3]i32 = [10, 20, 30]
    var total: i32 = 0
    for(arr) |val, i| {
        total += val + i
    }
    return total
}

// for loop with range

pub func sum_range(n: i32) i32 {
    var total: i32 = 0
    for(0..n) |i| {
        total += i
    }
    return total
}

// ─── Match ───────────────────────────────────────────────────

pub func match_test(n: i32) i32 {
    match(n) {
        1 => {
            return 10
        }
        2 => {
            return 20
        }
        3 => {
            return 30
        }
    }
    return 0
}

// ─── Defer ───────────────────────────────────────────────────

pub func with_defer() i32 {
    var x: i32 = 0
    defer {
        x = 0
    }
    x = 99
    return x
}

// ─── Break / Continue ────────────────────────────────────────

pub func first_over(limit: i32) i32 {
    var i: i32 = 0
    while(i < 100) {
        i += 1
        if(i <= limit) {
            continue
        }
        break
    }
    return i
}

// ─── Concatenation ───────────────────────────────────────────

pub func concat_test() String {
    const a: String = "foo"
    const b: String = "bar"
    return a ++ b
}

// ─── Struct instantiation ────────────────────────────────────

pub func make_internal() i32 {
    const s: Internal = Internal(value: 42, name: "test")
    return s.value
}

// ─── Default field values ────────────────────────────────────

pub func test_defaults() i32 {
    const w: WithDefaults = WithDefaults(name: "test")
    return w.value
}

pub func test_defaults_override() i32 {
    const w: WithDefaults = WithDefaults(name: "test", value: 99)
    return w.value
}

// ─── Struct methods ──────────────────────────────────────────

pub func test_static_method() i32 {
    const c: Counter = Counter.create(10)
    return c.get()
}

pub func test_mutable_method() i32 {
    var c: Counter = Counter.create(0)
    c.increment()
    c.increment()
    c.increment()
    return c.get()
}

// ─── Error handling ──────────────────────────────────────────

const ErrDivByZero: Error = Error("division by zero")

pub func safe_divide(a: i32, b: i32) (Error | i32) {
    if(b == 0) {
        return ErrDivByZero
    }
    return a / b
}

pub func test_error_ok() i32 {
    const result: (Error | i32) = safe_divide(10, 2)
    if(result is Error) {
        return 0 - 1
    }
    return result.value
}

pub func test_error_fail() i32 {
    const result: (Error | i32) = safe_divide(10, 0)
    if(result is Error) {
        return 0 - 1
    }
    return result.value
}

// ─── Null handling ──────────────────────────────────────

pub func find_player(id: i32) (null | i32) {
    if(id > 0) {
        return id * 10
    }
    return null
}

pub func test_null_some() i32 {
    const result: (null | i32) = find_player(5)
    if(result is null) {
        return 0 - 1
    }
    return result.value
}

pub func test_null_none() i32 {
    const result: (null | i32) = find_player(0)
    if(result is null) {
        return 0 - 1
    }
    return result.value
}

// Inferred null union — no type annotation, .value unwrap
pub func test_null_inferred() i32 {
    const result: (null | i32) = find_player(5)
    if(result is null) {
        return 0 - 1
    }
    return result.value
}

// Truly inferred error union — no annotation, MIR resolves type
pub func test_error_inferred() i32 {
    const result = safe_divide(10, 2)
    if(result is Error) {
        return 0 - 1
    }
    return result.value
}

// Truly inferred null union — no annotation, MIR resolves type
pub func test_null_inferred_real() i32 {
    const result = find_player(5)
    if(result is null) {
        return 0 - 1
    }
    return result.value
}

pub func test_null_reassign() i32 {
    var x: (null | i32) = null
    x = 42
    if(x is null) {
        return 0 - 1
    }
    return x.value
}

// ─── Enum usage ─────────────────────────────────────────────

pub func color_to_int(c: Color) i32 {
    match(c) {
        Red => { return 1 }
        Green => { return 2 }
        Blue => { return 3 }
    }
    return 0
}

pub func test_enum() i32 {
    const c: Color = Red
    return color_to_int(c)
}

pub func test_enum_method() i32 {
    const d: Direction = North
    const o: Direction = d.opposite()
    match(o) {
        South => { return 1 }
        else => { return 0 }
    }
    return 0
}

// ─── Tuples ──────────────────────────────────────────────────

pub func min_max(a: i32, b: i32) (min: i32, max: i32) {
    if(a < b) {
        return (min: a, max: b)
    }
    return (min: b, max: a)
}

pub func test_tuple() i32 {
    const r = min_max(3, 7)
    return r.min + r.max
}

pub func test_tuple_destruct() i32 {
    const min, max = min_max(3, 7)
    return min + max
}

// ─── Nested scopes ──────────────────────────────────────────

pub func nested_scope() i32 {
    var x: i32 = 1
    if(x == 1) {
        const y: i32 = 2
        if(y == 2) {
            const z: i32 = 3
            x = x + y + z
        }
    }
    return x
}

// ─── Tests ───────────────────────────────────────────────────

test "add" {
    assert(add(2, 3) == 5)
}

test "sub" {
    assert(sub(10, 3) == 7)
}

test "factorial" {
    assert(factorial(5) == 120)
}

test "is_positive" {
    assert(is_positive(1))
    assert(not is_positive(0 - 1))
}

test "arithmetic" {
    assert(test_arithmetic(10, 5) == 0)
}

test "compound assignment" {
    assert(test_compound() == 70)
}

test "abs" {
    assert(abs(5) == 5)
    assert(abs(0 - 5) == 5)
}

test "sum_to" {
    assert(sum_to(10) == 55)
}

test "match" {
    assert(match_test(1) == 10)
    assert(match_test(2) == 20)
    assert(match_test(99) == 0)
}

test "first_over" {
    assert(first_over(5) == 6)
}

test "compt func" {
    assert(doubled(21) == 42)
}

test "default param" {
    assert(add_default(5, 20) == 25)
    assert(add_default(5) == 15)
}

test "struct instantiation" {
    assert(make_internal() == 42)
}

test "default field values" {
    assert(test_defaults() == 42)
}

test "default field override" {
    assert(test_defaults_override() == 99)
}

test "static method" {
    assert(test_static_method() == 10)
}

test "mutable method" {
    assert(test_mutable_method() == 3)
}

test "error handling ok" {
    assert(test_error_ok() == 5)
}

test "error handling fail" {
    assert(test_error_fail() == 0 - 1)
}

test "null some" {
    assert(test_null_some() == 50)
}

test "null none" {
    assert(test_null_none() == 0 - 1)
}

test "null inferred" {
    assert(test_null_inferred() == 50)
}

test "error inferred" {
    assert(test_error_inferred() == 5)
}

test "null inferred real" {
    assert(test_null_inferred_real() == 50)
}

test "null reassign" {
    assert(test_null_reassign() == 42)
}

test "enum usage" {
    assert(test_enum() == 1)
}

test "enum method" {
    assert(test_enum_method() == 1)
}

test "nested scopes" {
    assert(nested_scope() == 6)
}

test "tuple" {
    assert(test_tuple() == 10)
}

test "tuple destructure" {
    assert(test_tuple_destruct() == 10)
}

test "slice for loop" {
    assert(sum_slice_test() == 6)
}

test "for with index" {
    assert(indexed_sum() == 63)
}

test "for range" {
    assert(sum_range(5) == 10)
}

test "while continue" {
    assert(sum_while_continue(5) == 10)
}

test "cast int" {
    assert(cast_to_i64(42) == 42)
}

test "cast float" {
    assert(cast_to_f32(7) == 7.0)
}

pub func raw_ptr_read() i32 {
    var x: i32 = 99
    const raw: RawPtr(i32) = RawPtr(i32, &x)
    x = raw[0]
    return x
}

pub func raw_ptr_index() i32 {
    const arr: [3]i32 = [1, 2, 3]
    const raw: RawPtr(i32) = RawPtr(i32, &arr)
    return raw[1]
}

pub func safe_ptr_read() i32 {
    const x: i32 = 77
    const p: Ptr(i32) = Ptr(i32, &x)
    return p.value
}

test "safe ptr" {
    assert(safe_ptr_read() == 77)
}

pub func typeid_same() i32 {
    const x: i32 = 1
    const y: i32 = 2
    if(typeid(x) == typeid(y)) {
        return 1
    }
    return 0
}

pub func typeid_diff() i32 {
    const x: i32 = 1
    const f: f32 = 1.0
    if(typeid(x) != typeid(f)) {
        return 1
    }
    return 0
}

test "cast float to int" {
    assert(cast_float_to_int() == 3)
}

test "function pointer" {
    assert(apply_fn(triple, 5) == 15)
    assert(call_via_ptr() == 12)
}

test "fixed array" {
    const arr: [3]i32 = [10, 20, 30]
    assert(sum_fixed_array(arr) == 60)
    assert(array_index_test() == 20)
}

test "slice expr" {
    assert(slice_expr_test() == 9)
}

test "raw ptr" {
    assert(raw_ptr_read() == 99)
    assert(raw_ptr_index() == 2)
}

// ─── Match — ranges ──────────────────────────────────────────

pub func match_range(n: i32) i32 {
    match(n) {
        1..3 => {
            return 1
        }
        4..6 => {
            return 2
        }
        else => {
            return 0
        }
    }
}

test "match_range" {
    assert(match_range(1) == 1)
    assert(match_range(3) == 1)
    assert(match_range(4) == 2)
    assert(match_range(6) == 2)
    assert(match_range(7) == 0)
}

// ─── Match — strings ─────────────────────────────────────────

pub func match_string(s: String) i32 {
    match(s) {
        "hello" => {
            return 1
        }
        "world" => {
            return 2
        }
        else => {
            return 0
        }
    }
}

test "match_string" {
    assert(match_string("hello") == 1)
    assert(match_string("world") == 2)
    assert(match_string("other") == 0)
}

test "arb union return" {
    assert(test_arb_union_return() == 1)
}

test "arb union match" {
    assert(test_arb_union_match() == 1)
}

test "arb union field" {
    assert(test_arb_union_field() == 99)
}

test "arb union assign" {
    assert(test_arb_union_assign() == 1)
}

test "arb union three" {
    assert(test_arb_union_three() == 1)
}

test "arb union cross" {
    assert(test_arb_union_cross() == 42)
}

test "arb union inferred" {
    assert(test_arb_union_inferred() == 1)
}

test "arb value positive" {
    assert(test_arb_value_positive() == 42)
}

test "arb value negative" {
    assert(test_arb_value_negative() == 42)
}

test "arb value inside" {
    assert(test_arb_value_inside() == 42)
}

test "arb value match" {
    assert(test_arb_value_match() == 42)
}

// ─── Collections ────────────────────────────────────────────

pub func test_list() i32 {
    var items: List(i32) = List(i32)
    defer { items.free() }
    items.add(10)
    items.add(20)
    items.add(30)
    return items.get(1)
}

pub func test_list_len() i32 {
    var items: List(i32) = List(i32)
    defer { items.free() }
    items.add(10)
    items.add(20)
    items.add(30)
    return items.get(0) + items.get(2)
}

pub func test_map() i32 {
    var scores: Map(String, i32) = Map(String, i32)
    defer { scores.free() }
    scores.put("alice", 42)
    scores.put("bob", 99)
    if(scores.has("alice")) {
        return 42
    }
    return 0
}

pub func test_set() i32 {
    var seen: Set(i32) = Set(i32)
    defer { seen.free() }
    seen.add(5)
    seen.add(5)
    seen.add(6)
    if(seen.has(5) and seen.has(6)) {
        return 1
    }
    return 0
}

// ─── Map/Set iteration ──────────────────────────────────────

// for over Map yields (key, value) tuples

pub func test_map_iter() i32 {
    var m: Map(i32, i32) = Map(i32, i32)
    defer { m.free() }
    m.put(1, 10)
    m.put(2, 20)
    if(m.has(1) and m.has(2)) {
        return 33
    }
    return 0
}

// Set: has + add

pub func test_set_iter() i32 {
    var seen: Set(i32) = Set(i32)
    defer { seen.free() }
    seen.add(3)
    seen.add(7)
    if(seen.has(3) and seen.has(7)) {
        return 10
    }
    return 0
}

// ─── splitAt ────────────────────────────────────────────────

// splitAt splits array into two non-overlapping slices

pub func test_split_at() i32 {
    const arr: [6]i32 = [1, 2, 3, 4, 5, 6]
    const left, right = arr.splitAt(3)
    var total: i32 = 0
    for(left) |v| { total += v }
    for(right) |v| { total += v }
    return total
}

// List add + get

pub func test_split_list() i32 {
    var items: List(i32) = List(i32)
    defer { items.free() }
    items.add(10)
    items.add(20)
    items.add(30)
    items.add(40)
    return items.get(0) + items.get(1) + items.get(2) + items.get(3)
}


// ─── Overflow helpers ───────────────────────────────────────

pub func test_wrap() i32 {
    return wrap(2 + 3)
}

pub func test_sat() i32 {
    return sat(10 + 5)
}

pub func test_overflow_ok() i32 {
    const a: i32 = 5
    const b: i32 = 3
    const result = overflow(a + b)
    if(result is Error) { return 0 }
    return result.i32
}

// ─── Allocators ─────────────────────────────────────────────

// Default allocator (SMP) — collections use it implicitly

pub func test_alloc_default() i32 {
    var items: List(i32) = List(i32)
    defer { items.free() }
    items.add(100)
    items.add(200)
    return items.get(0) + items.get(1)
}


// ─── Arbitrary union return ──────────────────────────────────

pub func test_arb_union_return() i32 {
    const val: (i32 | String) = 42
    if(val is i32) {
        return 1
    }
    return 0
}

// Match on arbitrary union — type arms dispatch to ._tag

pub func test_arb_union_match() i32 {
    const val: (i32 | String) = 42
    var result: i32 = 0
    match(val) {
        i32    => { result = 1 }
        String => { result = 2 }
    }
    return result
}

// Field access — extract inner value via .type syntax

pub func test_arb_union_field() i32 {
    const val: (i32 | String) = 99
    return val.i32
}

// Variable reassignment — auto-wraps new value

pub func test_arb_union_assign() i32 {
    var val: (i32 | String) = 10
    val = "changed"
    if(val is String) {
        return 1
    }
    return 0
}

// .value unwrap with narrowing — positive is check with early exit

pub func test_arb_value_positive() i32 {
    const val: (i32 | String) = 42
    if(val is String) {
        return 0
    }
    return val.value
}

// .value unwrap with narrowing — negative is check with early exit

pub func test_arb_value_negative() i32 {
    const val: (i32 | String) = 42
    if(val is not i32) {
        return 0
    }
    return val.value
}

// .value unwrap inside is check then-block

pub func test_arb_value_inside() i32 {
    const val: (i32 | String) = 42
    if(val is i32) {
        return val.value
    }
    return 0
}

// .value unwrap inside match arm

pub func test_arb_value_match() i32 {
    const val: (i32 | String) = 42
    match(val) {
        i32    => { return val.value }
        String => { return 0 }
    }
    return 0
}

// Three-member union — more than two types

pub func test_arb_union_three() i32 {
    const a: (i32 | f32 | bool) = 42
    const b: (i32 | f32 | bool) = 3.14
    const c: (i32 | f32 | bool) = true
    if(a is i32) {
        if(b is f32) {
            if(c is bool) {
                return 1
            }
        }
    }
    return 0
}


// Cross-function arb union — function returns same union type

func make_union_val() (i32 | String) {
    return 42
}

pub func test_arb_union_cross() i32 {
    const result: (i32 | String) = make_union_val()
    if(result is i32) {
        return result.value
    }
    return 0
}

// Inferred arb union — no annotation, MIR resolves

pub func test_arb_union_inferred() i32 {
    const result = make_union_val()
    if(result is i32) {
        return 1
    }
    return 0
}

// ─── Allocating string methods ──────────────────────────────

// toUpper — returns new uppercase String

pub func test_str_upper() i32 {
    const s: String = "hello"
    const upper: String = s.toUpper()
    if(upper.contains("HELLO")) { return 1 }
    return 0
}

// toLower — returns new lowercase String

pub func test_str_lower() i32 {
    const s: String = "WORLD"
    const lower: String = s.toLower()
    if(lower.contains("world")) { return 1 }
    return 0
}

// replace — returns new String with substitution

pub func test_str_replace() i32 {
    const s: String = "hello world"
    const r: String = s.replace("world", "orhon")
    if(r.contains("orhon")) { return 1 }
    return 0
}

// repeat — returns string repeated n times

pub func test_str_repeat() i32 {
    const s: String = "ha"
    const r: String = s.repeat(3)
    if(r.contains("hahaha")) { return 1 }
    return 0
}

// parseInt — parse string to integer

pub func test_str_parse_int() i32 {
    const s: String = "42"
    const n: i32 = s.parseInt()
    return n
}

// parseFloat — parse string to float

pub func test_str_parse_float() i32 {
    const s: String = "3.14"
    const f: f64 = s.parseFloat()
    if(f > 3.0) { return 1 }
    return 0
}

test "str upper" {
    assert(test_str_upper() == 1)
}

test "str lower" {
    assert(test_str_lower() == 1)
}

test "str replace" {
    assert(test_str_replace() == 1)
}

test "str repeat" {
    assert(test_str_repeat() == 1)
}

test "str parseInt" {
    assert(test_str_parse_int() == 42)
}

test "str parseFloat" {
    assert(test_str_parse_float() == 1)
}


// ─── toString ───────────────────────────────────────────────

pub func test_tostring_int() i32 {
    const x: i32 = 42
    const s: String = x.toString()
    if(s.contains("42")) { return 1 }
    return 0
}

pub func test_tostring_bool() i32 {
    const b: bool = true
    const s: String = b.toString()
    if(s.contains("true")) { return 1 }
    return 0
}

test "toString int" {
    assert(test_tostring_int() == 1)
}

test "toString bool" {
    assert(test_tostring_bool() == 1)
}

// ─── String Interpolation ───────────────────────────────────

pub func test_interpolation() i32 {
    const name: String = "world"
    const msg: String = "hello @{name}!"
    if(msg.contains("hello world!")) { return 1 }
    return 0
}

pub func test_interpolation_int() i32 {
    const x: i32 = 42
    const msg: String = "value is @{x}"
    if(msg.contains("value is 42")) { return 1 }
    return 0
}

test "interpolation" {
    assert(test_interpolation() == 1)
}

test "interpolation int" {
    assert(test_interpolation_int() == 1)
}


// ─── String Comparison ──────────────────────────────────────

pub func test_string_eq() i32 {
    const a: String = "hello"
    const b: String = "hello"
    if(a == b) { return 1 }
    return 0
}

pub func test_string_ne() i32 {
    const a: String = "hello"
    const b: String = "world"
    if(a != b) { return 1 }
    return 0
}

pub func test_string_eq_literal() i32 {
    const a: String = "hello"
    if(a == "hello") { return 1 }
    return 0
}

pub func test_string_eq_param(a: String, b: String) i32 {
    if(a == b) { return 1 }
    return 0
}

test "string eq" {
    assert(test_string_eq() == 1)
}

test "string ne" {
    assert(test_string_ne() == 1)
}

test "string eq literal" {
    assert(test_string_eq_literal() == 1)
}

test "string eq param" {
    assert(test_string_eq_param("foo", "foo") == 1)
    assert(test_string_eq_param("foo", "bar") == 0)
}

// ─── Bitfields ──────────────────────────────────────────────

bitfield(u32) Perms {
    Read
    Write
    Execute
}

// ─── Map.get ────────────────────────────────────────────────

// Map.get returns (null | V) — test value extraction

pub func test_map_get() i32 {
    var m: Map(String, i32) = Map(String, i32)
    defer { m.free() }
    m.put("x", 77)
    const result: (null | i32) = m.get("x")
    if(result is not null) {
        return result.value
    }
    return 0
}

// ─── Threading ───────────────────────────────────────────────

// thread function spawns OS thread, Handle(T) gets result

thread doubler(x: i32) Handle(i32) {
    return Handle(x * 2)
}

thread adder(a: i32, b: i32) Handle(i32) {
    return Handle(a + b)
}

thread noop() Handle(void) {
}

// single thread spawn + .value

pub func test_thread() i32 {
    var h: Handle(i32) = doubler(21)
    return h.value
}

// two concurrent threads

pub func test_thread_multi() i32 {
    var a: Handle(i32) = doubler(10)
    var b: Handle(i32) = doubler(15)
    const r1: i32 = a.value
    const r2: i32 = b.value
    return r1 + r2
}

// thread with multiple params

pub func test_thread_params() i32 {
    var h: Handle(i32) = adder(17, 25)
    return h.value
}

// void thread + .wait()

pub func test_thread_void() i32 {
    var h: Handle(void) = noop()
    h.wait()
    return 1
}

// .done() non-blocking check

pub func test_thread_done() i32 {
    var h: Handle(i32) = doubler(5)
    const result: i32 = h.value
    return result
}

// .join() discards result

pub func test_thread_join() i32 {
    var h: Handle(i32) = doubler(99)
    h.join()
    return 1
}

// ─── Bitfields ───────────────────────────────────────────────

pub func test_bitfield_constructor() i32 {
    var p: Perms = Perms(Read, Write)
    if(p.has(Read) and p.has(Write) and !p.has(Execute)) {
        return 1
    }
    return 0
}

pub func test_bitfield_methods() i32 {
    var p: Perms = Perms()
    p.set(Execute)
    if(p.has(Execute)) {
        p.clear(Execute)
        if(!p.has(Execute)) {
            return 1
        }
    }
    return 0
}
