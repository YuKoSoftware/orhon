module fixture

#name    = "fail_threads"
#version = (1, 0, 0)
#build   = exe

// thread function — unjoined handle

thread worker(x: i32) Handle(i32) {
    return Handle(x * 2)
}

func unjoined() void {
    const h: Handle(i32) = worker(42)
}

// thread function — use after move into thread

thread consumer(data: i32) Handle(i32) {
    return Handle(data)
}

func use_after_thread_move() void {
    var x: i32 = 42
    const h: Handle(i32) = consumer(x)
    const y: i32 = x
    const r: i32 = h.value
}

// thread function — mutate frozen variable (const borrow to thread)

thread reader(val: const& i32) Handle(void) {
}

func mutate_while_borrowed() void {
    var x: i32 = 10
    const h: Handle(void) = reader(mut& x)
    x = 20
    h.wait()
}

// thread function — mutable borrow to thread (rejected)

thread writer(val: mut& i32) Handle(void) {
}

func mutable_borrow_to_thread() void {
    var x: i32 = 10
    const h: Handle(void) = writer(mut& x)
    h.wait()
}

func main() void { }
