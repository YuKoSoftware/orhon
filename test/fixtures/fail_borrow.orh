module main

#name    = "fail_borrow"
#version = Version(1, 0, 0)
#build   = exe

struct Point {
    pub x: i32
    pub y: i32
}

// reference types not allowed in variable declarations

func ref_in_var() void {
    var p: Point = Point(x: 1, y: 2)
    var r: mut& Point = mut& p
}

func ref_in_const() void {
    var q: Point = Point(x: 3, y: 4)
    const r: const& Point = const& q
}

func main() void { }
