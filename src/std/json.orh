module json

// json — JSON parsing, querying, and building for Orhon programs
// Import with: import std::json

// Get a string value at a dot-path ("user.address.city")

pub bridge func get(source: String, path: String) (Error | String)

// Get an integer value at a dot-path

pub bridge func getInt(source: String, path: String) (Error | i64)

// Get a float value at a dot-path

pub bridge func getFloat(source: String, path: String) (Error | f64)

// Get a boolean value at a dot-path

pub bridge func getBool(source: String, path: String) (Error | bool)

// Get array elements at a dot-path (newline-separated)

pub bridge func getArray(source: String, path: String) (Error | String)

// Check if a key exists in a JSON string

pub bridge func hasKey(source: String, key: String) bool

// Build JSON from key-value pairs

pub bridge func object(keys: any, values: any) String

// Stringify a value to JSON

pub bridge func stringify(value: any) String

// Pretty-print a JSON string with indentation

pub bridge func pretty(source: String) (Error | String)
