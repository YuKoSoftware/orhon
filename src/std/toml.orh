module toml

// toml — TOML parsing for Orhon programs
// Import with: import std::toml

// Get a string value at a dot-path ("database.host")

pub bridge func get(source: String, path: String) (Error | String)

// Get an integer value at a dot-path

pub bridge func getInt(source: String, path: String) (Error | i64)

// Get a float value at a dot-path

pub bridge func getFloat(source: String, path: String) (Error | f64)

// Get a boolean value at a dot-path

pub bridge func getBool(source: String, path: String) (Error | bool)

// Get array elements at a dot-path (newline-separated)

pub bridge func getArray(source: String, path: String) (Error | String)

// Check if a key exists at a dot-path

pub bridge func hasKey(source: String, path: String) bool

// Get all keys in a table (newline-separated)

pub bridge func getKeys(source: String, table: String) (Error | String)
