module compression

// compression — gzip and zlib compression for Orhon programs
// Import with: import std::compression

// Compress data using gzip

pub bridge func gzipCompress(data: String) (Error | String)

// Decompress gzip data

pub bridge func gzipDecompress(data: String) (Error | String)

// Compress data using zlib (deflate)

pub bridge func zlibCompress(data: String) (Error | String)

// Decompress zlib data

pub bridge func zlibDecompress(data: String) (Error | String)
