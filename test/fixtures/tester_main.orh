    const arr: [3]i32 = [10, 20, 30]
    if(tester.sum_fixed_array(arr) == 60) {
        console.println("PASS fixed_array")
    } else {
        console.println("FAIL fixed_array")
    }

    if(tester.array_index_test() == 20) {
        console.println("PASS array_index")
    } else {
        console.println("FAIL array_index")
