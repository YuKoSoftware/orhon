module tester

blueprint Eq {
    func eq(self: const& Eq, other: const& Eq) bool
}

blueprint Measurable {
    func measure(self: const& Measurable) f32
}

struct Color: Eq, Measurable {
    r: u8
    g: u8
    b: u8

    pub func eq(self: const& Color, other: const& Color) bool {
        return self.r == other.r and self.g == other.g and self.b == other.b
    }

    pub func measure(self: const& Color) f32 {
        return 0.0
    }
}
