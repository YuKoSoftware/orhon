module comptest

#name    = "comptest"
#version = (1, 0, 0)
#build   = exe

import std::console
import std::string
import tester

func main() void {
    // Runtime correctness — each check calls a tester function
    // and prints PASS or FAIL. test.sh verifies no FAIL lines.

    if(tester.add(2, 3) == 5) {
        console.println("PASS add")
    } else {
        console.println("FAIL add")
    }

    if(tester.sub(10, 3) == 7) {
        console.println("PASS sub")
    } else {
        console.println("FAIL sub")
    }

    if(tester.factorial(5) == 120) {
        console.println("PASS factorial")
    } else {
        console.println("FAIL factorial")
    }

    if(tester.is_positive(1)) {
        console.println("PASS is_positive")
    } else {
        console.println("FAIL is_positive")
    }

    if(tester.test_compound() == 70) {
        console.println("PASS compound")
    } else {
        console.println("FAIL compound")
    }

    if(tester.sum_to(10) == 55) {
        console.println("PASS sum_to")
    } else {
        console.println("FAIL sum_to")
    }

    if(tester.match_test(1) == 10) {
        console.println("PASS match")
    } else {
        console.println("FAIL match")
    }

    if(tester.match_test(99) == 0) {
        console.println("PASS match_default")
    } else {
        console.println("FAIL match_default")
    }

    if(tester.first_over(5) == 6) {
        console.println("PASS break_continue")
    } else {
        console.println("FAIL break_continue")
    }

    if(tester.abs(0 - 7) == 7) {
        console.println("PASS abs")
    } else {
        console.println("FAIL abs")
    }

    if(tester.doubled(21) == 42) {
        console.println("PASS compt_func")
    } else {
        console.println("FAIL compt_func")
    }

    if(tester.add_default(5, 10) == 15) {
        console.println("PASS default_param")
