module fixture

#name    = "fail_structs"
#version = (1, 0, 0)
#build   = exe

// duplicate field name in struct

struct BadStruct {
    pub name: str
    pub name: i32
}

// missing required field in constructor

struct Config {
    pub host: str
    pub port: i32
}

func missing_field() void {
    const c: Config = Config(host: "localhost")
}

func main() void { }
