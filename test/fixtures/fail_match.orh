module fixture

#name    = "fail_match"
#version = (1, 0, 0)
#build   = exe

// match arm with a type that is not a member of the union

func get_result(flag: bool) ErrorUnion(i32) {
    if(flag) { return 42 }
    return Error("fail")
}

func bad_match_arm() void {
    const result = get_result(true)
    match(result) {
        Error  => { }
        str => { }
    }
}

// match on nullable with wrong arm type

func find(id: i32) NullUnion(i32) {
    if(id <= 0) { return null }
    return id
}

func bad_null_match() void {
    const val = find(1)
    match(val) {
        null   => { }
        str => { }
    }
}

func main() void { }
