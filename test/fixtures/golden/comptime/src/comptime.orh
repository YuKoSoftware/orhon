module comptime

pub compt func doubled(n: i32) i32 {
    return n * 2
}

pub func size_of_i32() i32 {
    return @size(i32)
}

compt func typeof_match(val: any) bool {
    const T: type = @typeOf(val)
    return T == i32
}

pub func check_type() bool {
    const x: i32 = 42
    return typeof_match(x)
}

compt func Wrapper(T: type) type {
    return struct {
        inner: T

        pub func get(self: const& @this) T {
            return self.inner
        }
    }
}

pub func make_wrapper() i32 {
    const w: Wrapper(i32) = Wrapper(i32){inner: 99}
    return w.get()
}
