    if(tester.test_mutable_method() == 3) {
        console.println("PASS mutable_method")
    } else {
        console.println("FAIL mutable_method")
    }

    if(tester.test_error_ok() == 5) {
        console.println("PASS error_ok")
    } else {
        console.println("FAIL error_ok")
    }

    if(tester.test_error_fail() == 0 - 1) {
        console.println("PASS error_fail")
    } else {
        console.println("FAIL error_fail")
    }

    if(tester.test_null_some() == 50) {
        console.println("PASS null_some")
    } else {
        console.println("FAIL null_some")
    }

    if(tester.test_null_none() == 0 - 1) {
        console.println("PASS null_none")
    } else {
        console.println("FAIL null_none")
    }

    if(tester.test_null_inferred() == 50) {
        console.println("PASS null_inferred")
