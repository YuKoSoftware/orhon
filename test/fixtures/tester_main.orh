        console.println("FAIL typeid_same")
    }

    if(tester.typeid_diff() == 1) {
        console.println("PASS typeid_diff")
    } else {
        console.println("FAIL typeid_diff")
    }

    if(tester.match_range(3) == 1 and tester.match_range(5) == 2 and tester.match_range(7) == 0) {
        console.println("PASS match_range")
    } else {
        console.println("FAIL match_range")
    }

    if(tester.match_string("hello") == 1 and tester.match_string("world") == 2 and tester.match_string("x") == 0) {
        console.println("PASS match_string")
    } else {
        console.println("FAIL match_string")
    }

    if(tester.test_list() == 20) {
        console.println("PASS list")
