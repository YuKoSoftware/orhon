    } else {
        console.println("FAIL func_ptr")
    }

    if(tester.call_via_ptr() == 12) {
        console.println("PASS func_ptr_var")
    } else {
        console.println("FAIL func_ptr_var")
    }

    if(tester.cast_to_i64(42) == 42) {
        console.println("PASS cast_int")
