module main

#name    = "fail_structs"
#version = Version(1, 0, 0)
#build   = exe
#bitsize = 32

// duplicate field name in struct

struct BadStruct {
    pub name: String
    pub name: i32
}

// missing required field in constructor

struct Config {
    pub host: String
    pub port: i32
}

func missing_field() void {
    const c: Config = Config(host: "localhost")
}

func main() void { }
