    if(string.contains(greet_result, "hello world")) {
        console.println("PASS greeting")
    } else {
        console.println("FAIL greeting")
    }

    const concat_result: str = tester.concat_test()
    if(string.contains(concat_result, "foobar")) {
        console.println("PASS concat")
    } else {
        console.println("FAIL concat")
    }

    if(tester.make_internal() == 42) {
        console.println("PASS struct_instantiation")
